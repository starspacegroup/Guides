# Auth.js Secret (generate with: openssl rand -base64 32)
AUTH_SECRET=your-secret-key-here

# GitHub OAuth Application Credentials
# Create at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:4242/api/auth/github/callback
# For production: https://yourdomain.com/api/auth/github/callback
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Your GitHub username (find at: https://github.com/YOUR_USERNAME)
# Only this user will be able to create, update, and delete content
AUTHORIZED_USER_NAME=your-github-username
